{"model_key": "gpt_sovits", "model_name": "GPT-SoVITS-V3", "model_size_params": "~200M", "is_llm_based": true, "supported_languages": ["ko", "en", "ja", "zh"], "lang": "en", "method": "A", "ref_key": "en_female", "text_key": "en_names", "text": "Apple CEO Tim Cook met with Microsoft founder Bill Gates in New York City last Tuesday. Their discussion focused on arti", "wav_path": "results_multilingual\\wav\\en\\A\\gpt_sovits__en_names_0.wav", "success": true, "load_time_s": 3.845472900007735, "ttfa_ms": 7603.509099993971, "inference_time_s": 7.603509099993971, "audio_duration_s": 22.314666666666668, "rtf": 0.3407, "sample_rate": 24000, "vram_before_mb": 0.0, "vram_after_mb": 1924.83056640625, "vram_peak_mb": 2287.3994140625, "cer": null, "wer": null, "stt_text": null, "timestamp": "2026-03-05T08:34:33.152140"}

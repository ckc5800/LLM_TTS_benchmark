{"model_key": "cosyvoice3", "model_name": "CosyVoice3-0.5B", "model_size_params": "500M", "is_llm_based": true, "supported_languages": ["ko", "en", "ja", "zh"], "lang": "zh", "method": "A", "ref_key": "zh_female", "text_key": "zh_conversational", "text": "哎，你今天中午吃什么？我想吃火锅，最近天气冷，吃点热乎的最舒服了。你有什么想法吗？", "wav_path": "results_multilingual\\wav\\zh\\A\\cosyvoice3__zh_conversational_0.wav", "success": true, "load_time_s": 21.682046599991736, "ttfa_ms": 5495.4940999887185, "inference_time_s": 5.499102899993886, "audio_duration_s": 9.88, "rtf": 0.5566, "sample_rate": 24000, "vram_before_mb": 0.0, "vram_after_mb": 3284.8349609375, "vram_peak_mb": 3564.36474609375, "cer": null, "wer": null, "stt_text": null, "timestamp": "2026-03-05T08:54:28.316003"}
